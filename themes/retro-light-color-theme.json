{
    "$schema": "vscode://schemas/color-theme",
    "name": "Retro Light",
    "colors": {
        "checkbox.border": "#919191",
        "editor.background": "#d9d9d9",
        "editor.foreground": "#080808",
        "editor.lineHighlightBorder": "#cccccc",
        "editorLineNumber.foreground": "#a6a6a6",
        "editorLineNumber.activeForeground": "#4d4d4d",
        "editor.inactiveSelectionBackground": "#0c2e8d15",
        "editor.selectionBackground": "#0c2e8d25",
        "editorIndentGuide.background1": "#cccccc",
        "editorIndentGuide.activeBackground1": "#a6a6a6",

        "terminal.ansiBlack": "#080808",
        "terminal.ansiBlue": "#1750EB",
        "terminal.ansiBrightBlack": "#080808",
        "terminal.ansiBrightBlue": "#1750EB",
        "terminal.ansiBrightCyan": "#00627A",
        "terminal.ansiBrightGreen": "#067D17",
        "terminal.ansiBrightMagenta": "#660E7A",
        "terminal.ansiBrightRed": "#CE0505",
        "terminal.ansiBrightWhite": "#FFFFFF",
        "terminal.ansiBrightYellow": "#76660a",
        "terminal.ansiCyan": "#00627A",
        "terminal.ansiGreen": "#067D17",
        "terminal.ansiMagenta": "#660E7A",
        "terminal.ansiRed": "#CE0505",
        "terminal.ansiWhite": "#FFFFFF",
        "terminal.ansiYellow": "#76660a",
        "terminal.background": "#d9d9d9",
        "terminal.foreground": "#080808"
    },
    "semanticHighlighting": true,
    "semanticTokenColors": {
        "customLiteral": "#080808",
        "newOperator": "#080808",
        "numberLiteral": "#660E7A",
        "stringLiteral": "#067D17"
    },
    "tokenColors": [
        {
            "name": "keyword or other syntax",
            "scope": "punctuation.terminator,punctuation.quasi.element",
            "settings": {
                "foreground": "#0033B3"
            }
        },
        {
            "name": "entities",
            "scope": "entity.name,support.type.property-name.json",
            "settings": {
                "foreground": "#1750EB"
            }
        },
        {
            "scope": "support.type,constant.character.escape",
            "settings": {
                "foreground": "#76660a"
            }
        },
        {
            "scope": "constant.language",
            "settings": {
                "foreground": "#660E7A"
            }
        },
        {
            "name": "no highlight",
            "scope": "variable,string.unquoted.argument.shell,storage.type.object,storage.type.java,constant.other.option",
            "settings": {
                "foreground": "#080808"
            }
        },
        {
            "scope": "entity.name.function,support.function,keyword.control.twig",
            "settings": {
                "foreground": "#00627A"
            }
        },
        {
            "scope": [
                "meta.embedded",
                "source.groovy.embedded",
                "string meta.image.inline.markdown"
            ],
            "settings": {
                "foreground": "#080808"
            }
        },
        {
            "scope": "emphasis",
            "settings": {
                "fontStyle": "italic"
            }
        },
        {
            "scope": "strong",
            "settings": {
                "fontStyle": "bold"
            }
        },
        {
            "name": "Comment",
            "scope": "comment",
            "settings": {
                "foreground": "#8C8C8C",
                "fontStyle": "italic"
            }
        },
        {
            "name": "block comment",
            "scope": "comment.block",
            "settings": {
                "foreground": "#8C8C8C",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "constant.numeric",
                "variable.other.enummember",
                "keyword.operator.plus.exponent",
                "keyword.operator.minus.exponent"
            ],
            "settings": {
                "foreground": "#660E7A"
            }
        },
        {
            "scope": "constant.regexp",
            "settings": {
                "foreground": "#0033B3"
            }
        },
        {
            "scope": "entity.name.tag",
            "settings": {
                "foreground": "#0033B3",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "entity.name.tag.css",
                "entity.name.tag.less"
            ],
            "settings": {
                "foreground": "#0033B3"
            }
        },
        {
            "scope": "entity.other.attribute-name",
            "settings": {
                "foreground": "#1750EB"
            }
        },
        {
            "scope": [
                "entity.other.attribute-name.class.css",
                "source.css entity.other.attribute-name.class",
                "entity.other.attribute-name.id.css",
                "entity.other.attribute-name.parent-selector.css",
                "entity.other.attribute-name.parent.less",
                "source.css entity.other.attribute-name.pseudo-class",
                "entity.other.attribute-name.pseudo-element.css",
                "source.css.less entity.other.attribute-name.id",
                "entity.other.attribute-name.scss"
            ],
            "settings": {
                "foreground": "#76660a"
            }
        },
        {
            "scope": "invalid",
            "settings": {
                "foreground": "#CE0505"
            }
        },
        {
            "scope": "markup.underline",
            "settings": {
                "fontStyle": "underline"
            }
        },
        {
            "scope": "markup.bold",
            "settings": {
                "fontStyle": "bold",
                "foreground": "#0033B3"
            }
        },
        {
            "scope": "markup.heading",
            "settings": {
                "fontStyle": "bold",
                "foreground": "#0033B3"
            }
        },
        {
            "scope": "markup.italic",
            "settings": {
                "fontStyle": "italic"
            }
        },
        {
            "scope": "markup.strikethrough",
            "settings": {
                "fontStyle": "strikethrough"
            }
        },
        {
            "scope": "markup.inserted",
            "settings": {
                "foreground": "#660E7A"
            }
        },
        {
            "scope": "markup.deleted",
            "settings": {
                "foreground": "#067D17"
            }
        },
        {
            "scope": "markup.changed",
            "settings": {
                "foreground": "#0033B3"
            }
        },
        {
            "scope": "punctuation.definition.quote.begin.markdown",
            "settings": {
                "foreground": "#067D17"
            }
        },
        {
            "scope": "punctuation.definition.list.begin.markdown",
            "settings": {
                "foreground": "#00627A"
            }
        },
        {
            "scope": "markup.inline.raw",
            "settings": {
                "foreground": "#067D17"
            }
        },
        {
            "name": "brackets of XML/HTML tags",
            "scope": "punctuation.definition.tag",
            "settings": {
                "foreground": "#737373"
            }
        },
        {
            "scope": [
                "meta.preprocessor",
                "entity.name.function.preprocessor"
            ],
            "settings": {
                "foreground": "#0033B3"
            }
        },
        {
            "scope": "meta.preprocessor.string",
            "settings": {
                "foreground": "#067D17"
            }
        },
        {
            "scope": "meta.preprocessor.numeric",
            "settings": {
                "foreground": "#660E7A"
            }
        },
        {
            "scope": "meta.diff.header",
            "settings": {
                "foreground": "#0033B3"
            }
        },
        {
            "scope": "storage",
            "settings": {
                "foreground": "#0033B3",
                "fontStyle": "bold"
            }
        },
        {
            "scope": "storage.type",
            "settings": {
                "foreground": "#0033B3",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "storage.modifier",
                "keyword.operator.noexcept"
            ],
            "settings": {
                "foreground": "#0033B3",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "string",
                "meta.embedded.assembly"
            ],
            "settings": {
                "foreground": "#067D17"
            }
        },
        {
            "scope": "string.tag",
            "settings": {
                "foreground": "#067D17"
            }
        },
        {
            "scope": "string.value",
            "settings": {
                "foreground": "#067D17"
            }
        },
        {
            "scope": "string.regexp",
            "settings": {
                "foreground": "#067D17"
            }
        },
        {
            "name": "String interpolation",
            "scope": [
                "punctuation.definition.template-expression.begin",
                "punctuation.definition.template-expression.end",
                "punctuation.section.embedded"
            ],
            "settings": {
                "foreground": "#0033B3"
            }
        },
        {
            "name": "Reset JavaScript string interpolation expression",
            "scope": [
                "meta.template.expression"
            ],
            "settings": {
                "foreground": "#080808"
            }
        },
        {
            "scope": [
                "support.type.vendored.property-name",
                "support.type.property-name",
                "source.css variable",
                "source.coffee.embedded"
            ],
            "settings": {
                "foreground": "#080808"
            }
        },
        {
            "scope": "keyword",
            "settings": {
                "foreground": "#0033B3",
                "fontStyle": "bold"
            }
        },
        {
            "scope": "keyword.control",
            "settings": {
                "foreground": "#0033B3"
            }
        },
        {
            "scope": "keyword.operator",
            "settings": {
                "foreground": "#080808",
                "fontStyle": ""
            }
        },
        {
            "scope": [
                "keyword.operator.new",
                "keyword.operator.expression",
                "keyword.operator.cast",
                "keyword.operator.sizeof",
                "keyword.operator.alignof",
                "keyword.operator.typeid",
                "keyword.operator.alignas",
                "keyword.operator.instanceof",
                "keyword.operator.logical.python",
                "keyword.operator.wordlike"
            ],
            "settings": {
                "foreground": "#0033B3",
                "fontStyle": "bold"
            }
        },
        {
            "scope": "keyword.other.unit",
            "settings": {
                "foreground": "#660E7A",
                "fontStyle": ""
            }
        },
        {
            "scope": [
                "punctuation.section.embedded.begin.php",
                "punctuation.section.embedded.end.php"
            ],
            "settings": {
                "foreground": "#0033B3"
            }
        },
        {
            "scope": "constant.sha.git-rebase",
            "settings": {
                "foreground": "#660E7A"
            }
        },
        {
            "name": "coloring of the Java import and package identifiers",
            "scope": [
                "storage.modifier.import.java",
                "variable.language.wildcard.java",
                "storage.modifier.package.java"
            ],
            "settings": {
                "foreground": "#080808"
            }
        },
        {
            "name": "this.self",
            "scope": "variable.language",
            "settings": {
                "foreground": "#0033B3",
                "fontStyle": "bold"
            }
        },
        {
            "name": "built in properties",
            "scope": [
                "support.constant.property-value",
                "keyword.control.at-rule"
            ],
            "settings": {
                "foreground": "#1750EB"
            }
        }
    ]
}
