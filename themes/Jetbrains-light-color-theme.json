{
    "$schema": "vscode://schemas/color-theme",
    "name": "Jetbrains Light Min",
    "colors": {
        "checkbox.border": "#919191",
        "editor.background": "#FFFFFF",
        "editor.foreground": "#080808",
        "editor.inactiveSelectionBackground": "#E5EBF1",
        "editorIndentGuide.background1": "#D3D3D3",
        "editorIndentGuide.activeBackground1": "#939393",
        "editor.selectionHighlightBackground": "#ADD6FF80",
        "editorSuggestWidget.background": "#F3F3F3",
        "activityBarBadge.background": "#007ACC",
        "sideBarTitle.foreground": "#6F6F6F",
        "list.hoverBackground": "#E8E8E8",
        "menu.border": "#D4D4D4",
        "input.placeholderForeground": "#767676",
        "searchEditor.textInputBorder": "#CECECE",
        "settings.textInputBorder": "#CECECE",
        "settings.numberInputBorder": "#CECECE",
        "statusBarItem.remoteForeground": "#FFF",
        "statusBarItem.remoteBackground": "#16825D",
        "ports.iconRunningProcessForeground": "#369432",
        "sideBarSectionHeader.background": "#0000",
        "sideBarSectionHeader.border": "#61616130",
        "tab.selectedForeground": "#333333b3",
        "tab.selectedBackground": "#ffffffa5",
        "tab.lastPinnedBorder": "#61616130",
        "notebook.cellBorderColor": "#E8E8E8",
        "notebook.selectedCellBackground": "#c8ddf150",
        "statusBarItem.errorBackground": "#c72e0f",
        "list.activeSelectionIconForeground": "#FFF",
        "list.focusAndSelectionOutline": "#90C2F9",
        "terminal.inactiveSelectionBackground": "#E5EBF1",
        "widget.border": "#d4d4d4",
        "actionBar.toggledBackground": "#dddddd",
        "diffEditor.unchangedRegionBackground": "#f8f8f8",

        "terminal.ansiBlack": "#080808",
        "terminal.ansiBlue": "#063FDB",
        "terminal.ansiBrightBlack": "#080808",
        "terminal.ansiBrightBlue": "#063FDB",
        "terminal.ansiBrightCyan": "#028E8E",
        "terminal.ansiBrightGreen": "#067D17",
        "terminal.ansiBrightMagenta": "#B309B3",
        "terminal.ansiBrightRed": "#CE0505",
        "terminal.ansiBrightWhite": "#FFFFFF",
        "terminal.ansiBrightYellow": "#B28C00",
        "terminal.ansiCyan": "#028E8E",
        "terminal.ansiGreen": "#067D17",
        "terminal.ansiMagenta": "#B309B3",
        "terminal.ansiRed": "#CE0505",
        "terminal.ansiWhite": "#C9C9C9",
        "terminal.ansiYellow": "#B28C00",
        "terminal.background": "#ffffff",
        "terminal.foreground": "#080808"
    },
    "tokenColors": [
        {
            "name": "keyword or other syntax",
            "scope": "punctuation.terminator,constant.character.escape,punctuation.quasi.element",
            "settings": {
                "foreground": "#0033B3"
            }
        },
        {
            "name": "no highlight",
            "scope": "variable.parameter,variable.other,string.unquoted.argument.shell,storage.type.object,storage.type.java,constant.other.option",
            "settings": {
                "foreground": "#080808"
            }
        },
        {
            "scope": [
                "meta.embedded",
                "source.groovy.embedded",
                "string meta.image.inline.markdown",
                "variable.legacy.builtin.python"
            ],
            "settings": {
                "foreground": "#080808"
            }
        },
        {
            "scope": "emphasis",
            "settings": {
                "fontStyle": "italic"
            }
        },
        {
            "scope": "strong",
            "settings": {
                "fontStyle": "bold"
            }
        },
        {
            "scope": "header",
            "settings": {
                "foreground": "#0033B3"
            }
        },
        {
            "name": "Comment",
            "scope": "comment",
            "settings": {
                "foreground": "#808080"
            }
        },
        {
            "name": "block comment",
            "scope": "comment.block",
            "settings": {
                "foreground": "#808080",
                "fontStyle": "italic"
            }
        },
        {
            "scope": "constant.language",
            "settings": {
                "foreground": "#0033B3"
            }
        },
        {
            "scope": [
                "constant.numeric",
                "variable.other.enummember",
                "keyword.operator.plus.exponent",
                "keyword.operator.minus.exponent",
                "entity.other.attribute-name.html",
                "entity.other.attribute-name.localname.xml"
            ],
            "settings": {
                "foreground": "#1750EB"
            }
        },
        {
            "scope": "constant.regexp",
            "settings": {
                "foreground": "#646695"
            }
        },
        {
            "scope": "entity.name.tag",
            "settings": {
                "foreground": "#0033B3"
            }
        },
        {
            "scope": ["entity.name.tag.css", "entity.name.tag.less"],
            "settings": {
                "foreground": "#0033B3"
            }
        },
        {
            "scope": "entity.other.attribute-name",
            "settings": {
                "foreground": "#7C1E8F"
            }
        },
        {
            "scope": [
                "entity.other.attribute-name.class.css",
                "source.css entity.other.attribute-name.class",
                "entity.other.attribute-name.id.css",
                "entity.other.attribute-name.parent-selector.css",
                "entity.other.attribute-name.parent.less",
                "source.css entity.other.attribute-name.pseudo-class",
                "entity.other.attribute-name.pseudo-element.css",
                "source.css.less entity.other.attribute-name.id",
                "entity.other.attribute-name.scss"
            ],
            "settings": {
                "foreground": "#0033B3"
            }
        },
        {
            "scope": "invalid",
            "settings": {
                "foreground": "#CE0505"
            }
        },
        {
            "scope": "markup.underline",
            "settings": {
                "fontStyle": "underline"
            }
        },
        {
            "scope": "markup.bold",
            "settings": {
                "fontStyle": "bold",
                "foreground": "#0033B3"
            }
        },
        {
            "scope": "markup.heading",
            "settings": {
                "fontStyle": "bold",
                "foreground": "#0033B3"
            }
        },
        {
            "scope": "markup.italic",
            "settings": {
                "fontStyle": "italic"
            }
        },
        {
            "scope": "markup.strikethrough",
            "settings": {
                "fontStyle": "strikethrough"
            }
        },
        {
            "scope": "markup.inserted",
            "settings": {
                "foreground": "#1750EB"
            }
        },
        {
            "scope": "markup.deleted",
            "settings": {
                "foreground": "#067D17"
            }
        },
        {
            "scope": "markup.changed",
            "settings": {
                "foreground": "#0033B3"
            }
        },
        {
            "scope": "punctuation.definition.quote.begin.markdown",
            "settings": {
                "foreground": "#067D17"
            }
        },
        {
            "scope": "punctuation.definition.list.begin.markdown",
            "settings": {
                "foreground": "#0033B3"
            }
        },
        {
            "scope": "markup.inline.raw",
            "settings": {
                "foreground": "#067D17"
            }
        },
        {
            "name": "brackets of XML/HTML tags",
            "scope": "punctuation.definition.tag",
            "settings": {
                "foreground": "#080808"
            }
        },
        {
            "scope": ["meta.preprocessor", "entity.name.function.preprocessor"],
            "settings": {
                "foreground": "#0033B3"
            }
        },
        {
            "scope": "meta.preprocessor.string",
            "settings": {
                "foreground": "#067D17"
            }
        },
        {
            "scope": "meta.preprocessor.numeric",
            "settings": {
                "foreground": "#1750EB"
            }
        },
        {
            "scope": "meta.structure.dictionary.key.python",
            "settings": {
                "foreground": "#7C1E8F"
            }
        },
        {
            "scope": "meta.diff.header",
            "settings": {
                "foreground": "#0033B3"
            }
        },
        {
            "scope": "storage",
            "settings": {
                "foreground": "#0033B3"
            }
        },
        {
            "scope": "storage.type",
            "settings": {
                "foreground": "#0033B3"
            }
        },
        {
            "scope": ["storage.modifier", "keyword.operator.noexcept"],
            "settings": {
                "foreground": "#0033B3"
            }
        },
        {
            "scope": [
                "string",
                "meta.embedded.assembly",
                "support.type.property-name.json"
            ],
            "settings": {
                "foreground": "#067D17"
            }
        },
        {
            "scope": "string.tag",
            "settings": {
                "foreground": "#067D17"
            }
        },
        {
            "scope": "string.value",
            "settings": {
                "foreground": "#067D17"
            }
        },
        {
            "scope": "string.regexp",
            "settings": {
                "foreground": "#AC8D2D"
            }
        },
        {
            "name": "String interpolation",
            "scope": [
                "punctuation.definition.template-expression.begin",
                "punctuation.definition.template-expression.end",
                "punctuation.section.embedded"
            ],
            "settings": {
                "foreground": "#0033B3"
            }
        },
        {
            "name": "Reset JavaScript string interpolation expression",
            "scope": ["meta.template.expression"],
            "settings": {
                "foreground": "#080808"
            }
        },
        {
            "scope": [
                "support.type.vendored.property-name",
                "support.type.property-name",
                "source.css variable",
                "source.coffee.embedded"
            ],
            "settings": {
                "foreground": "#080808"
            }
        },
        {
            "scope": "keyword",
            "settings": {
                "foreground": "#0033B3"
            }
        },
        {
            "scope": "keyword.control",
            "settings": {
                "foreground": "#0033B3"
            }
        },
        {
            "scope": "keyword.operator",
            "settings": {
                "foreground": "#080808"
            }
        },
        {
            "scope": [
                "keyword.operator.new",
                "keyword.operator.expression",
                "keyword.operator.cast",
                "keyword.operator.sizeof",
                "keyword.operator.alignof",
                "keyword.operator.typeid",
                "keyword.operator.alignas",
                "keyword.operator.instanceof",
                "keyword.operator.logical.python",
                "keyword.operator.wordlike"
            ],
            "settings": {
                "foreground": "#0033B3"
            }
        },
        {
            "scope": "keyword.other.unit",
            "settings": {
                "foreground": "#1750EB"
            }
        },
        {
            "scope": [
                "punctuation.section.embedded.begin.php",
                "punctuation.section.embedded.end.php"
            ],
            "settings": {
                "foreground": "#0033B3"
            }
        },
        {
            "scope": "support.function.git-rebase",
            "settings": {
                "foreground": "#7C1E8F"
            }
        },
        {
            "scope": "constant.sha.git-rebase",
            "settings": {
                "foreground": "#1750EB"
            }
        },
        {
            "name": "coloring of the Java import and package identifiers",
            "scope": [
                "storage.modifier.import.java",
                "variable.language.wildcard.java",
                "storage.modifier.package.java"
            ],
            "settings": {
                "foreground": "#080808"
            }
        },
        {
            "name": "this.self",
            "scope": "variable.language",
            "settings": {
                "foreground": "#0033B3"
            }
        },
        {
            "name": "built in properties",
            "scope": [
                "support.constant.property-value",
                "keyword.control.at-rule",
                "keyword.control.twig",
                "support.type.property-name.json"
            ],
            "settings": {
                "foreground": "#7C1E8F"
            }
        }
    ],
    "semanticHighlighting": true,
    "semanticTokenColors": {
        "newOperator": "#0033B3",
        "stringLiteral": "#BD291D",
        "customLiteral": "#080808",
        "numberLiteral": "#098658"
    }
}
